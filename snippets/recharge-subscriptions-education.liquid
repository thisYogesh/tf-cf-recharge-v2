{% comment %}
  Recharge Affinity portal — Subscriptions page Education Zone.
  Injected into the subscriptions.footer slot via content extension.
  Liquid filters do NOT process inside <script type="text/html"> blocks,
  so all asset URLs must be hardcoded CDN paths.

  Structure (per Recharge Affinity best practice):
    1. <style> block — outside the slot, applies CSS globally on the page
    2. <script type="text/html"> — slot HTML content only (no nested <script>)
    3. No JS needed — content is static
{% endcomment %}

{%- comment -%} Education Zone CSS — placed OUTSIDE the slot so it loads normally {%- endcomment -%}
<style>
  /* =============================================
     Education Zone — Subscriptions Page Footer
     ============================================= */

  /* --- Base / Mobile Layout (image + text card) --- */
  .rc-education {
    border-radius: 8px;
    background: #E6F0F8;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    margin-top: 16px;
  }

  .rc-education__image {
    width: 100%;
    display: block;
    object-fit: cover;
  }

  .rc-education__text-lockup {
    padding: 12px 16px 16px 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .rc-education__header {
    display: flex;
    flex-direction: column;
    gap: 8px;
    justify-content: flex-end;
    padding-top: 8px;
  }

  .rc-education__eyebrow {
    font-family: monospace;
    font-size: 10px;
    line-height: 14px;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    color: #202635;
    margin: 0;
  }

  .rc-education__headline {
    font-size: 14px;
    line-height: 20px;
    letter-spacing: -0.14px;
    color: #202635;
    margin: 0;
    font-weight: 400;
  }

  /* Desktop icon hidden on mobile */
  .rc-education__icon {
    display: none;
    flex-shrink: 0;
  }

  /* Desktop body paragraph hidden on mobile */
  .rc-education__body {
    display: none;
  }

  /* Mobile learn more link: border-bottom style with arrow */
  .rc-education__link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 14px;
    line-height: 20px;
    color: #202635;
    text-decoration: none;
    border-bottom: 1px solid #202635;
    padding-bottom: 4px;
    align-self: flex-start;
    cursor: pointer;
  }

  .rc-education__link:hover {
    opacity: 0.7;
  }

  .rc-education__link-arrow {
    font-size: 11px;
    line-height: 13px;
    text-align: center;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
  }

  /* Desktop headline hidden on mobile */
  .rc-education__headline--desktop {
    display: none;
  }

  /* Desktop link (underline style, hidden on mobile) */
  .rc-education__link--desktop {
    display: none;
  }

  /* --- Desktop Layout (text-only card) --- */
  @media screen and (min-width: 750px) {
    .rc-education {
      border-radius: 16px;
      background: #D9E8F4;
      padding: 20px;
      gap: 12px;
    }

    /* Hide mobile image on desktop */
    .rc-education__image {
      display: none;
    }

    .rc-education__text-lockup {
      padding: 0;
      gap: 12px;
    }

    .rc-education__header {
      flex-direction: row;
      justify-content: space-between;
      gap: 8px;
      padding-top: 0;
    }

    .rc-education__header-content {
      display: flex;
      flex-direction: column;
      gap: 12px;
      justify-content: flex-end;
      padding-top: 8px;
    }

    .rc-education__eyebrow {
      font-size: 14px;
      line-height: 20px;
      letter-spacing: 0.56px;
    }

    .rc-education__headline {
      font-size: 18px;
      line-height: 25px;
      letter-spacing: 0;
      font-family: inherit;
    }

    /* Show desktop headline, hide mobile headline on desktop */
    .rc-education__headline--desktop {
      display: block;
    }

    .rc-education__headline--mobile {
      display: none;
    }

    /* Show desktop icon */
    .rc-education__icon {
      display: flex;
      align-items: flex-start;
      flex-shrink: 0;
    }

    /* Show desktop body paragraph */
    .rc-education__body {
      display: block;
      font-size: 16px;
      line-height: 22px;
      color: #202635;
      margin: 0;
      font-weight: 400;
    }

    /* Hide mobile link on desktop */
    .rc-education__link--mobile {
      display: none;
    }

    /* Show desktop link (underlined text style) */
    .rc-education__link--desktop {
      display: inline;
      font-size: 16px;
      line-height: 23px;
      color: #202635;
      text-decoration: underline;
      cursor: pointer;
      border-bottom: none;
      padding-bottom: 0;
      align-self: flex-start;
    }

    .rc-education__link--desktop:hover {
      opacity: 0.7;
    }
  }
</style>

{%- comment -%} Education Zone HTML — injected into the subscriptions.footer slot {%- endcomment -%}
<script type="text/html" data-recharge-slot="subscriptions.footer">
  <div class="rc-education">
    <!-- Mobile: image banner (hidden on desktop via CSS) -->
    <img
      class="rc-education__image"
      src="https://cdn.shopify.com/s/files/1/1000/8959/4135/files/media-desktop-I1150861211376605.png?v=1782377262"
