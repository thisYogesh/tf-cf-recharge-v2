    <!-- Text lockup -->
    <div class="rc-education__text-lockup">
      <div class="rc-education__header">
        <div class="rc-education__header-content">
          <p class="rc-education__eyebrow">DID YOU KNOW?</p>
          <!-- Mobile headline -->
          <p class="rc-education__headline rc-education__headline--mobile">
            Regular replacement ensures consistent contaminant reduction and retains beneficial minerals in every glass.
          </p>
          <!-- Desktop headline -->
          <p class="rc-education__headline rc-education__headline--desktop">
            Your Water is actively protected from 25 harmful contaminants!
          </p>
        </div>

        <!-- Desktop: 48px blue circle icon (hidden on mobile via CSS) -->
